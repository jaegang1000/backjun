#define _CRT_SECURE_NO_WARNINGS
#include<stdio.h>
int main() {
	int i, j;
	int a[3];
	int min;
	int input;
	int temp;
	for (i = 0; i < 3; i++) {
		scanf(" %d", &input);
		a[i] = input;
	}
	for (i = 1; i < 3; i++) {
		for (j = i; j < 3; j++) {
			if (a[i - 1] > a[j]) {
				temp = a[i - 1];
				a[i-1] = a[j];
				a[j] = temp;
			}
		}
	}
	for (i = 0; i < 3; i++) {
		printf("%d ", a[i]);
	}
}
