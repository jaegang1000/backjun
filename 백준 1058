	for (i = 0; i < n; i++) {
		a[i] = (char*)malloc(sizeof(char) * n);
	}
	for (i = 0; i < n; i++) {
		for (j = 0; j < n; j++) {
			scanf(" %c", &a[i][j]);
			if (i == j) {
				while (a[i][j] == 'Y') {
					a[i][j] = 'N';
				}
			}
