#define _CRT_SECURE_NO_WARNINGS
#include<stdio.h>
#include<string.h>

int main() {
	int i, j, k, count0 = 0, count1 = 0, count=0;
	char s[1000001];
	scanf("%s", &s);
	for (i = 0; i < strlen(s)-1; i++) {
		if (s[i] == '0' && s[i + 1] != '0') {
			count0++;
		}
		if (s[i] == '1' && s[i + 1] != '1') {
			count1++;
		}
		if (s[strlen(s) - 1] == '0') {
			count0++;
		}
		if (s[strlen(s) - 1] == '1') {
			count1++;
		}
	}
	
	if (count1 > count0) {
		printf("%d", count0);
	}
	else {
		printf("%d", count1);
	}
}
