#define _CRT_SECURE_NO_WARNINGS
#include<stdio.h>
#include<stdlib.h>
int main() {
	int i, j, k, l;
	int input;
	int num = 1, coloum=1, row=1;
	int count = 0;
	scanf("%d", &input);
	while (count<input) {
		if (num % 2 == 0) {
			for (i = 1; i < num + 1; i++) {
				count++;
				k = i;
				j = num - k + 1;
				if (count == input) {
					break;
				}

			}
		}
		if (num % 2 == 1) {
			for (i = 1; i < num + 1; i++) {
				count++;
				j = i;
				k = num - j + 1;
				if (count == input) {
					break;
				}

			}
		}
		
		num++;
	}
	printf("%d/%d", k, j);
}
