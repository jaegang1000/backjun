#define _CRT_SECURE_NO_WARNINGS
#include<stdio.h>
#include<stdlib.h>

int min(int n1, int n2, int n3) {
	int a[3] = { n1, n2, n3 };
	int mn = a[0];
	for (int i = 0; i < 3; i++) {
		if (a[i] < mn) {
			mn = a[i];
		}
	}
	return mn;
}
int main(void) {
	int N;
	int count = 0;
	scanf("%d", &N);
	int* dp = (int*)malloc(sizeof(int) * (N+1));
	dp[0] = 0;
	dp[1] = 0;
	dp[2] = 1;
	dp[3] = 1;
	dp[4] = 2;
	for (int i = 5; i < N + 1; i++) {
		if (i % 3 == 0 && i % 2 != 0) {
			dp[i] = min(dp[i - 1] + 1, dp[i / 3] + 1, dp[i / 3] + 1);
		}
		else if (i % 3 != 0 && i % 2 == 0) {
			dp[i] = min(dp[i - 1] + 1, dp[i / 2] + 1, dp[i / 2] + 1);
		}
		else if (i % 3 == 0 && i % 2 == 0) {
			dp[i] = min(dp[i - 1] + 1, dp[i / 2] + 1, dp[i / 3] + 1);
		}
		else if (i % 3 != 0 && i % 2 != 0) {
			dp[i] = min(dp[i - 1] + 1, dp[i - 1] + 1, dp[i - 1] + 1);
		}
	}
	printf("%d", dp[N]);
	return 0;
}
