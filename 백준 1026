#define _CRT_SECURE_NO_WARNINGS
#include<stdio.h>
#include<stdlib.h>
int main() {
	int N;
	int na;
	scanf("%d", &na);
	int* a = (int*)malloc(sizeof(int) * N);
	int nb;
	scanf("%d", &nb);
	int* b = (int*)malloc(sizeof(int) * N);
	for (i = 0; i < N; i++) {
		printf("%d\n", a[i]);
		printf("%d\n", b[i]);
	}
	return 0;
}
