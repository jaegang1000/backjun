#include<iostream>
#include<vector>
#include<stdlib.h>
using namespace std;
int** a;
int** b;
int M, N, T, K;
int* count;
void repeat(int x, int y) {
	if (x<0 || x>=M || y<0 || y>=N) {
		return;
	}
	if (a[y][x] == 0) {
		return;
	}
	if (a[y][x] == 1 && b[y][x] == 1) {
		return;
	}
	if (a[y][x] == 1 && b[y][x] == 0) {
		b[y][x] = 1;
		repeat(x + 1, y);
		repeat(x, y + 1);
		repeat(x - 1, y);
		repeat(x, y - 1);
	}
	
}
int main() {
	int i, j, k, x, y;
	int n;
	int i1, j1, k1;
	int i2, j2, k2;
	cin >> T;
	::count=(int*)malloc(sizeof(int) * T);
	for (i = 0; i < T; i++) {
		::count[i] = 0;
	}
	for (i = 0; i < T; i++) {
		cin >> M >> N >> K;
		a = (int**)malloc(sizeof(int*) * N);
		b = (int**)malloc(sizeof(int*) * N);
		for (j = 0; j < N; j++) {
			a[j] = (int*)malloc(sizeof(int) * M);
			b[j] = (int*)malloc(sizeof(int) * M);
			for (k = 0; k < M; k++) {
				a[j][k] = 0;
				b[j][k] = 0;
			}
		}
		for (j1 = 0; j1 < K; j1++) {
			cin >> x >> y;
			a[y][x] = 1;
		}
		for (j2 = 0; j2 < N; j2++) {
			for (k2 = 0; k2 < M; k2++) {
				if (a[j2][k2] == 1 && b[j2][k2] == 0) {
					repeat(k2, j2);
					::count[i]++;
				}

			}
		}
	}
	
	for (i = 0; i < T; i++) {
		cout << ::count[i] << endl;
	}
}
