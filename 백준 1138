#include<iostream>
#include<vector>
using namespace std;
int main() {
	int i, j, k;
	int count = 0;
	int count2 = 0;
	int N, n;
	vector<int>a;
	vector<int>b;
	cin >> N;
	for (i = 0; i < N; i++) {
		cin >> n;
		a.push_back(n);
		b.push_back(0);
	}
	for (i = 0; i < N; i++) {
		count = 0;
		count2 = 0;
		while (1) {
			count2 = 0;
			for (j = 0; j < a[i] + count; j++) {
				if (b[j] == 0) {
					count2++;
				}
			}
			if (count2 < a[i]) {
				count++;
			}
			if (count2 == a[i] && b[a[i] + count] != 0) {
				count++;
			}
			if (count2 == a[i] && b[a[i] + count] == 0) {
				break;
			}
		}
		if (b[a[i] + count] == 0) {
			b[a[i] + count] = i + 1;
		}
	}
	for (i = 0; i < N; i++) {
		cout << b[i] << " ";
	}
}
